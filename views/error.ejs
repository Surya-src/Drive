<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= status %> - <%= message %></title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }
        .error-container {
            background: white;
            border-radius: 10px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
            padding: 40px;
            text-align: center;
            max-width: 500px;
            width: 100%;
        }
        .error-code {
            font-size: 80px;
            font-weight: bold;
            color: #667eea;
            margin-bottom: 10px;
        }
        .error-message {
            font-size: 24px;
            color: #333;
            margin-bottom: 10px;
        }
        .error-description {
            font-size: 16px;
            color: #666;
            margin-bottom: 30px;
            line-height: 1.6;
        }
        .back-link {
            display: inline-block;
            background: #667eea;
            color: white;
            padding: 12px 30px;
            border-radius: 5px;
            text-decoration: none;
            transition: background 0.3s ease;
            margin: 5px;
        }
        .back-link:hover {
            background: #764ba2;
        }
        .home-link {
            display: inline-block;
            background: #27ae60;
            color: white;
            padding: 12px 30px;
            border-radius: 5px;
            text-decoration: none;
            transition: background 0.3s ease;
            margin: 5px;
        }
        .home-link:hover {
            background: #229954;
        }
    </style>
</head>
<body>
    <div class="error-container">
        <div class="error-code"><%= status %></div>
        <div class="error-message"><%= message %></div>
        <div class="error-description">
            <% if(typeof description !== 'undefined') { %>
                <%= description %>
            <% } else { %>
                <% if(status === 404) { %>
                    The page you are looking for might have been removed or is temporarily unavailable.
                <% } else if(status === 401) { %>
                    You don't have permission to access this resource. Please log in first.
                <% } else if(status === 500) { %>
                    Something went wrong on our end. Please try again later.
                <% } else { %>
                    An error has occurred. Please try again.
                <% } %>
            <% } %>
        </div>
        <div>
            <a href="javascript:history.back()" class="back-link">← Go Back</a>
            <a href="/" class="home-link">🏠 Home</a>
        </div>
    </div>
</body>
</html>
